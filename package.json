{
  "name": "tartsi-magic-circle-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A React and TypeScript magic circle generator that uses a geometric symbolic language and wave-function-collapse-inspired constraints.",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "doctor": "node ./scripts/doctor.mjs",
    "setup": "node ./scripts/setup.mjs",
    "start": "node ./scripts/start-development.mjs",
    "dev": "vite",
    "build": "node ./scripts/build.mjs",
    "build:application": "vite build",
    "build:docs": "node ./scripts/build-docs.mjs",
    "build:all": "node ./scripts/build-all.mjs",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check \"README.md\" \"START_HERE.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \".github/**/*.md\" \".github/**/*.yml\" \"documentation-site/**/*.md\" \"wiki/**/*.md\" \"*.md\" \"*.json\" \".*.json\" \"*.yml\" \".*.yml\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:repository": "python -m pytest tests/test_repository.py",
    "test:all": "node ./scripts/test-all.mjs",
    "docs:api": "typedoc",
    "docs:site:dev": "vitepress dev documentation-site",
    "docs:site:build": "vitepress build documentation-site",
    "docs:wiki:serve": "docker compose -f wiki/docker-compose.yml up",
    "pages:build": "node ./scripts/build-pages.mjs",
    "quality:verify": "npm run format:check && npm run lint && npm run test && npm run build && npm run build:docs"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "9.38.0",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/jest-axe": "3.5.9",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "9.38.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "29.0.0",
    "jest-axe": "10.0.0",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "8.0.0",
    "vitepress": "1.6.4",
    "vitest": "4.1.0"
  }
}
